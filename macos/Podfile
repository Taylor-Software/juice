platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # flutter_gemma's macOS native-asset hook (through 1.1.0) downloads LiteRtLm's
  # dependency dylib libGemmaModelConstraintProvider.dylib into its cache but
  # does NOT embed it, so LiteRtLm.framework fails to dlopen at runtime
  # (Library not loaded: @rpath/libGemmaModelConstraintProvider.dylib). Copy it
  # into the app's Frameworks dir — resolved via LiteRtLm's @loader_path/../../..
  # rpath, so the framework's own signature stays intact. Upstream bug; drop this
  # once flutter_gemma bundles the dylib. See
  # docs/superpowers/notes/2026-06-22-macos-litertlm-dylib.md
  phase_name = 'Embed flutter_gemma LiteRtLm dylib'
  embed_script = <<-SCRIPT
SRC="$HOME/Library/Caches/flutter_gemma/native/macos_arm64/libGemmaModelConstraintProvider.dylib"
DST="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}"
if [ -f "$SRC" ] && [ -d "$DST" ]; then
  cp -f "$SRC" "$DST/libGemmaModelConstraintProvider.dylib"
  codesign --force --sign - "$DST/libGemmaModelConstraintProvider.dylib" || true
else
  echo "warning: flutter_gemma LiteRtLm dylib not embedded (SRC=$SRC DST=$DST)"
fi
  SCRIPT
  installer.aggregate_targets.each do |agg|
    project = agg.user_project
    next unless project
    project.native_targets.each do |target|
      next unless target.name == 'Runner'
      next if target.shell_script_build_phases.any? { |p| p.name == phase_name }
      phase = target.new_shell_script_build_phase(phase_name)
      phase.shell_script = embed_script
      project.save
    end
  end
end
